{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --ext .js,.ts,.vue",
    "lint:fix": "eslint . --ext .js,.ts,.vue --fix",
    "vitest": "npx vitest",
    "component-tests": "npx vitest run spec/components/*",
    "playwright": "npx playwright test",
    "wait-then-playwright": "./wait-for-rails.sh && npx playwright test",
    "rails-server": "cd ../backend && rails server",
    "front-and-back-dev": "concurrently -n 'BACKEND,FRONTEND' -c 'green,yellow' 'npm:rails-server' 'npm:dev'",
    "e2e-tests": "concurrently -n 'RAILS_SERVER,NUXT_SERVER,PLAYWRIGHT' -c 'blue,green,yellow' 'npm:rails-server' 'npm:dev' 'npm:wait-then-playwright'"
  },
  "dependencies": {
    "@nuxt/eslint": "^1.2.0",
    "@nuxt/fonts": "^0.11.0",
    "@nuxt/icon": "^1.11.0",
    "@nuxt/image": "^1.9.0",
    "@nuxt/test-utils": "^3.17.2",
    "@nuxtjs/color-mode": "^3.5.2",
    "@nuxtjs/tailwindcss": "^6.13.2",
    "@playwright/test": "^1.51.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/vite": "^4.0.14",
    "@vueuse/nuxt": "^13.0.0",
    "nuxt": "^3.16.0",
    "pixelmatch": "^7.1.0",
    "playwright-expect": "^0.1.2",
    "radix-vue": "^1.9.17",
    "tailwind-variants": "^1.0.0",
    "tailwindcss": "^4.0.14",
    "tailwindcss-animate": "^1.0.7",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.8",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@iconify-json/lucide": "^1.2.29",
    "@nuxt/eslint-config": "^1.2.0",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.1.2",
    "eslint": "^9.22.0",
    "eslint-plugin-nuxt": "^4.0.0",
    "happy-dom": "^17.4.4",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8",
    "wait-on": "^8.0.3"
  }
}
